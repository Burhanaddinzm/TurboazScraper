# If user wants to provide pre-filtered URL
FILTERED_URL=

# Discord webhook url for notifications
DISCORD_WEBHOOK_URL=

# Cars exceeding this number is skipped
SCRAPER_MAX_VIEWS=500

# Price range
SCRAPER_MIN_PRICE=3000
SCRAPER_MAX_PRICE=12000

# Milage range
SCRAPER_MIN_MILEAGE=0
SCRAPER_MAX_MILEAGE=250000

# Year range
SCRAPER_YEAR_MIN=1995
SCRAPER_YEAR_MAX=2025

# See only sellers that take credit as payment or barter the vehicle
SCRAPER_CREDIT=false
SCRAPER_BARTER=false

# Config for make and current location of cars
SCRAPER_MARKETS=Rəsmi diler,Avropa
SCRAPER_WHITELIST_CITY=Bakı,Sumqayıt